{
  "name": "hallucinated-talles",
  "private": true,
  "version": "1.0.0",
  "description": "AI-powered writing studio for authors — organize chapters, characters, events, and world data with intelligent assistance.",
  "author": "Hallucinated Talles Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/atretador/story_teller.git"
  },
  "bugs": {
    "url": "https://github.com/atretador/story_teller/issues"
  },
  "homepage": "https://github.com/atretador/story_teller#readme",
  "keywords": [
    "ai",
    "writing",
    "storytelling",
    "electron",
    "rich-text-editor",
    "manuscript",
    "creative-writing",
    "llm",
    "openai",
    "mcp"
  ],
  "main": "./out/main/index.mjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "test": "vitest",
    "lint": "oxlint",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "package": "electron-builder"
  },
  "build": {
    "appId": "com.hallucinated-talles.app",
    "productName": "Hallucinated Talles",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "out/main/pdf.worker.mjs"
    ],
    "icon": "build/icon.png",
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Office"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-toggle": "^1.1.13",
    "@shabalinmax/tiptap-scout": "^0.5.0",
    "@tiptap/extension-character-count": "^3.27.1",
    "@tiptap/extension-color": "^3.27.1",
    "@tiptap/extension-font-family": "^3.27.1",
    "@tiptap/extension-highlight": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-subscript": "^3.27.1",
    "@tiptap/extension-superscript": "^3.27.1",
    "@tiptap/extension-task-item": "^3.27.1",
    "@tiptap/extension-task-list": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-text-style": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@types/dagre": "^0.7.54",
    "@xyflow/react": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dagre": "^0.8.5",
    "electron-store": "^10.1.0",
    "express": "^4.22.2",
    "get-port": "^7.2.0",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-resources-to-backend": "^1.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.23.0",
    "mammoth": "^1.12.0",
    "motion": "^12.42.0",
    "openai": "^6.45.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "recharts": "^3.9.0",
    "sharp": "^0.35.2",
    "tailwind-merge": "^3.6.0",
    "turndown": "^7.2.4",
    "tw-animate-css": "^1.4.0",
    "zundo": "^2.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jszip": "^3.4.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^25.0.1",
    "oxlint": "^1.71.0",
    "prettier": "^3.9.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "vite": "^8.1.0",
    "vitest": "^3.2.6",
    "wait-on": "^8.0.5"
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  }
}
